{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "librolibre.cl" }],
      "destination": "https://tuslibros.cl/:path*?utm_source=librolibre&utm_medium=redirect",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-rankings",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup-bots",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/seo-report",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/mp-nudge",
      "schedule": "0 14 * * *"
    }
  ]
}
