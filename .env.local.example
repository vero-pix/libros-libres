# ─────────────────────────────────────────────
# Supabase
# Obtené estos valores en: https://supabase.com/dashboard → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Opcional: para operaciones server-side con permisos elevados (service_role)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────
# Mapbox GL JS
# Obtené tu token en: https://account.mapbox.com/access-tokens
# Alcances mínimos requeridos: styles:read, tiles:read, geocoding
# ─────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ─────────────────────────────────────────────
# Google Books API (opcional — funciona sin key con límite reducido)
# Obtené tu API key en: https://console.cloud.google.com → APIs → Books API
# ─────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY=AIza...

# ─────────────────────────────────────────────
# MercadoPago
# Obtén tus credenciales en: https://www.mercadopago.cl/developers/panel/app
# ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# ─────────────────────────────────────────────
# Next.js
# ─────────────────────────────────────────────
# URL pública de tu app (usada para redirects de auth y webhooks de pago)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
